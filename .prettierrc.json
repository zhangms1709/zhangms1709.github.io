{
  "printWidth": 100,
  "tabWidth": 4,
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSameLine": false,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.html",
      "options": { "tabWidth": 4, "printWidth": 120 }
    },
    {
      "files": "*.{json,yml,yaml}",
      "options": { "tabWidth": 2 }
    }
  ]
}
